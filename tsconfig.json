{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": false,
    "noImplicitAny": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitThis": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowJs": true,
    "declaration": false,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": false
  },
  "include": ["src"],
  "ts-node": {
    "transpileOnly": true
  }
}
